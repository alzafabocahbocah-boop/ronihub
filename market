local stopReq = false
local isRunning = false
local startGradient
local startGradTask

local function setStartIdle()
    isRunning = false
    startBtn.BackgroundColor3 = C.card
    startBtn.TextColor3 = C.textDim
    startBtn.Text = "⚡ START"
    startStroke.Color = C.accent
    startStroke.Transparency = 0.5
    startStroke.Thickness = 1.5
    -- Stop & remove animated gradient
    if startGradient then
        pcall(function() startGradient:Destroy() end)
        startGradient = nil
    end
end

local function setStartRunning()
    isRunning = true
    -- KEEP background gray (NOT yellow), only animate outline
    startBtn.BackgroundColor3 = C.card
    startBtn.TextColor3 = C.accent
    startBtn.Text = "⏸ STOP"
    startStroke.Color = Color3.fromRGB(255, 255, 255)  -- white base so gradient shows
    startStroke.Thickness = 2
    startStroke.Transparency = 0

    -- Add rotating gradient on outline (sweeping border animation)
    if startGradient then pcall(function() startGradient:Destroy() end) end
    startGradient = Instance.new("UIGradient")
    startGradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, C.accent),
        ColorSequenceKeypoint.new(0.5, Color3.fromRGB(255, 255, 200)),
        ColorSequenceKeypoint.new(1, C.accent),
    })
    startGradient.Parent = startStroke

    -- Spin the gradient
    task.spawn(function()
        local r = 0
        while isRunning and startGradient and startGradient.Parent do
            r = (r + 4) % 360
            startGradient.Rotation = r
            task.wait(0.03)
        end
    end)
end
setStartIdle()

local function setStats(text, color)
    statsLbl.Text = text
    statsLbl.TextColor3 = color or C.success
end

startBtn.MouseButton1Click:Connect(function()
    -- If already running → request stop
    if isRunning then
        stopReq = true
        L("⛔ STOP requested")
        return
    end
    -- Start
    setStartRunning()
    task.spawn(function()
        stopReq = false
        L("")
        L("==== START AUTO LIST ====")
        local delaySec = tonumber(delayBox.Text) or 3
        local maxRetry = tonumber(retryBox.Text) or 2
        local autoRejoinN = tonumber(autoRejoinBox.Text) or 0

        L("Rules: "..#listingRules)
        for i, r in ipairs(listingRules) do
            local maxStr = r.max == math.huge and "∞" or tostring(r.max)
            local mlStr = (r.maxListings == math.huge or not r.maxListings) and "∞" or tostring(r.maxListings)
            L("  ["..i.."] "..(r.type or "All").." | KG "..r.min.."–"..maxStr.." | 💰"..r.price.." | 📋"..mlStr)
        end
        L("Delay: "..delaySec.." | Retry: "..maxRetry)

        -- Per-rule counter
        local ruleCount = {}
        for i, _ in ipairs(listingRules) do ruleCount[i] = 0 end

        -- Helper: find matching rule for pet (returns rule + idx)
        local function matchRule(pType, wt)
            if #listingRules == 0 then
                return {price = perTypePrices[pType] or 100, maxListings = math.huge}, 0
            end
            for i, r in ipairs(listingRules) do
                local typeOk = (not r.type) or r.type == pType
                local kgOk = wt >= r.min and wt <= r.max
                local ml = r.maxListings or math.huge
                if typeOk and kgOk and ruleCount[i] < ml then return r, i end
            end
            return nil
        end

        local bp = player:FindFirstChild("Backpack")
        if not bp then
            L("[ERR] no backpack")
            setStats("ERR: no backpack", C.danger)
            setStartIdle()
            return
        end

        -- Diagnose: count pets + dump COMPLETE structure of first pet
        local allPets, favCount = 0, 0
        local typeCount = {}
        local baseAttrFound = nil
        local dumpedPet = false
        for _, t in ipairs(bp:GetChildren()) do
            if isPet(t) then
                allPets = allPets + 1
                if isFav(t) then
                    favCount = favCount + 1
                else
                    local pType = getPetType(t)
                    typeCount[pType] = (typeCount[pType] or 0) + 1
                    if not baseAttrFound then
                        local _, attr = getBaseKg(t)
                        if attr then baseAttrFound = attr end
                    end
                    -- Dump first non-fav pet COMPLETELY
                    if not dumpedPet then
                        dumpedPet = true
                        L("======================================")
                        L("[DUMP] "..t.Name)
                        L("[DUMP] Attributes:")
                        for k, v in pairs(t:GetAttributes()) do
                            L("    "..k.." ("..typeof(v)..") = "..tostring(v))
                        end
                        L("[DUMP] Children:")
                        for _, ch in ipairs(t:GetChildren()) do
                            local extra = ""
                            if ch:IsA("ValueBase") then extra = " VALUE="..tostring(ch.Value) end
                            L("    "..ch.ClassName.." '"..ch.Name.."'"..extra)
                            -- Inspect child attributes too
                            for k, v in pairs(ch:GetAttributes()) do
                                L("      attr "..k.." = "..tostring(v))
                            end
                        end
                        L("======================================")
                    end
                end
            end
        end
        L("Backpack: "..allPets.." pets ("..favCount.." favorited)")
        local typesStr = ""
        for tp, c in pairs(typeCount) do typesStr = typesStr..tp.."="..c.." " end
        L("Non-fav by type: "..typesStr)
        if baseAttrFound then
            if baseAttrFound == "formula" then
                L("✅ Base KG via FORMULA: baseKG = currentKG × 11 / (age + 10)")
            else
                L("✅ Base KG via attribute: '"..baseAttrFound.."'")
            end
        else
            L("⚠ Base KG tidak bisa dihitung — pakai current weight")
        end

        -- Build todo + match rules (using BASE weight if available)
        local todo = {}
        local matchedCount = 0
        for _, t in ipairs(bp:GetChildren()) do
            if isPet(t) and not isFav(t) then
                local uuid = tostring(t:GetAttribute("PET_UUID") or t.Name)
                local clean = uuid:gsub("^{",""):gsub("}$","")
                local pType = getPetType(t)
                local currentKg = getCurrentKg(t)
                local baseKg = getBaseKg(t) or currentKg  -- fallback to current if no base
                -- Pre-check if any rule could match this pet (use base weight)
                local hasMatch = false
                if #listingRules == 0 then hasMatch = true
                else
                    for _, r in ipairs(listingRules) do
                        local typeOk = (not r.type) or r.type == pType
                        local kgOk = baseKg >= r.min and baseKg <= r.max
                        if typeOk and kgOk then hasMatch = true; break end
                    end
                end
                if hasMatch then matchedCount = matchedCount + 1 end
                table.insert(todo, {
                    name=t.Name, braced="{"..clean.."}",
                    type=pType, wt=baseKg, currentKg=currentKg,
                    tries=0
                })
            end
        end
        L("Eligible (non-fav): "..#todo.." | Match rules: "..matchedCount)

        if #todo == 0 then
            local msg
            if allPets == 0 then msg = "No pets in backpack"
            elseif favCount >= allPets then msg = "All pets favorited (skip)"
            else msg = "0 non-fav pets" end
            setStats(msg, C.danger)
            setStartIdle()
            return
        end
        if matchedCount == 0 and #listingRules > 0 then
            setStats("0 pets match rules — cek base KG range", C.danger)
            L("[INFO] Pets exist tapi gak match rules.")
            L("[INFO] Cek pet type & KG range di rule udah bener?")
            setStartIdle()
            return
        end

        -- Total max
        local totalMax = 0
        for _, r in ipairs(listingRules) do
            local ml = r.maxListings or math.huge
            if ml == math.huge then totalMax = math.huge; break end
            totalMax = totalMax + ml
        end
        if #listingRules == 0 then totalMax = math.huge end
        L("Total max listings: "..(totalMax == math.huge and "∞" or totalMax))

        local sukses, fail = 0, 0
        local i = 1
        while i <= #todo and not stopReq do
            local p = todo[i]
            local rule, ruleIdx = matchRule(p.type, p.wt)
            if not rule then
                i = i + 1
            else
                p.tries = p.tries + 1
                local mlInfo = ruleIdx > 0 and (" [r"..ruleIdx.."]") or ""
                L("["..sukses.."] "..p.type.." (base "..string.format("%.1f", p.wt).."kg, cur "..string.format("%.1f", p.currentKg).."kg) @ "..rule.price..mlInfo)
                local ok, id = listPet(p.braced, rule.price)
                if ok then
                    sukses = sukses + 1
                    if ruleIdx > 0 then ruleCount[ruleIdx] = ruleCount[ruleIdx] + 1 end
                    L("   ✅ "..id:sub(1,12).."...")
                    if autoRejoinN > 0 and sukses % autoRejoinN == 0 then
                        L("   🔄 AUTO-REJOIN setelah "..sukses.." sukses")
                        task.wait(1)
                        pcall(function() TeleportService:Teleport(game.PlaceId, player) end)
                        return
                    end
                else
                    L("   ❌")
                    if p.tries < maxRetry then table.insert(todo, p) else fail = fail + 1 end
                end
                i = i + 1
                setStats(string.format("Running... ✅ %d  |  ❌ %d", sukses, fail), C.accent)
