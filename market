                l.Font = font or FM l.TextSize = size or 11
                l.TextXAlignment = Enum.TextXAlignment.Left
                l.TextTruncate = Enum.TextTruncate.AtEnd l.Parent = row
            end
            cell(p.type, 0, 0.3, C.text, FB)
            cell(p.mutation, 0.3, 0.22, C.accent)
