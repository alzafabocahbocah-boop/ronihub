            BH.snBuy.refresh.BackgroundColor3 = C.danger
            L("[HUNT] AUTO-RESUME from state, scanning server #"..BH.hunt.scanned)
            pcall(scanBoothListings)
            pcall(renderBuy)
        end
    end)
