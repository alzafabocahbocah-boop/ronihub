local function tryClaim()
    L("")
    L("==== CLAIM BOOTH ====")
    local hrp = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not hrp then L("[skip] no char") return end
    local TW = Workspace:FindFirstChild("TradeWorld")
