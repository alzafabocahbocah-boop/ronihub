            -- v8.78: rate-limit handling
            local globalCooldownUntil = 0
            local removed = 0
            local rateFails = 0

            for i, listingUuid in ipairs(allUuids) do
                -- Check global cooldown sebelum tiap pet
                if tick() < globalCooldownUntil then
                    local waitLeft = math.ceil(globalCooldownUntil - tick())
                    L("[Unlist-ALL] ⏸ rate-limit pause "..waitLeft.."s sebelum unlist ke-"..i)
                    statusLbl.Text = "⏸ Rate limited — wait "..waitLeft.."s"
