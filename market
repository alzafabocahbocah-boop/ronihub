                    L("[TP-Market] try remote: "..c:GetFullName())
                    pcall(function()
                        if c:IsA("RemoteFunction") then c:InvokeServer()
                        else c:FireServer() end
                    end)
                    fired = true
                    break
                end
            end
        end
