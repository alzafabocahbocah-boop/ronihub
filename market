local function makeCollapsibleCard(parent, title, defaultExpanded)
    local card = Instance.new("Frame")
    card.Size = UDim2.new(1, -8, 0, 44)
    card.BackgroundColor3 = C.card
    card.BorderSizePixel = 0
    card.ClipsDescendants = true
