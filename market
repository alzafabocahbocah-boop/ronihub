        if t:IsA("Tool") then table.insert(listings, tostring(t:GetAttribute("PET_UUID") or t.Name)) end
    end
    local removed = 0
    for _, uuid in ipairs(listings) do
        local clean = uuid:gsub("^{",""):gsub("}$","")
        local braced = "{"..clean.."}"
        for _, args in ipairs({{"Pet", braced}, {braced}, {"Pet", clean}, {clean}}) do
